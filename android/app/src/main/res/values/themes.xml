<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Edge-to-edge: statusBarColor is ignored on SDK 35+.
         enableEdgeToEdge() handles system bar appearance per-activity. -->
    <style name="Theme.Ekatra" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/ekatra_blue</item>
        <item name="colorPrimaryDark">@color/ekatra_blue_dark</item>
        <item name="colorAccent">@color/ekatra_accent</item>
        <item name="android:windowBackground">@color/background</item>
    </style>
    
    <style name="Theme.Ekatra.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/ekatra_blue</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@color/background</item>
    </style>
</resources>
