rules_version = '2';

// Firestore Security Rules for Maya AI (org.ekatra.alfred)
// Upload to: Firebase Console → Firestore Database → Rules
//
// Collections:
//   /users/{userId}                    — User profile (name, country, grade, etc.)
//   /users/{userId}/analytics/{docId}  — Per-session analytics (synced by SyncWorker)
//   /fcm_tokens/{tokenId}             — FCM push notification tokens (optional)

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== User Profiles ====================
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;

      // ==================== User Analytics ====================
      // Users can write their own analytics; only admins can read all
      match /analytics/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ==================== FCM Tokens (optional) ====================
    // Any authenticated user can register their token
    // Only the token owner can delete it
    match /fcm_tokens/{tokenId} {
      allow create, update: if request.auth != null;
      allow read, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ==================== Default Deny ====================
    // Everything else is denied by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
